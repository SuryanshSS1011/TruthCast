{
  "manifest_version": 3,
  "name": "TruthCast",
  "version": "1.0.0",
  "description": "Autonomous AI fact-checking with immutable blockchain provenance",
  "permissions": [
    "storage",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/index.html"
  }
}
