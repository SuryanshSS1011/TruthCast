# Gemini API
GEMINI_API_KEY=

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=              # Available voices: Sarah (EXAVITQu4vr4xnSDxMaL), Charlie (IKne3meq5aSn9XLyUdCD), George (JBFqnCBsd6RMkjVDRZzb)

# Solana (Devnet only)
SOLANA_PUBLIC_KEY=
SOLANA_PRIVATE_KEY=       # Base58 encoded keypair for devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Solana Frontend (Public - safe to expose)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_PUBLIC_KEY=    # Same as SOLANA_PUBLIC_KEY above

# Sentry Error Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Database / Cache
SQLITE_PATH=./packages/pipeline/db/truthcast.db

# Upstash Redis (for Vercel deployment)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Messaging Channels (Optional - for Telegram and Discord bots)
TELEGRAM_BOT_TOKEN=               # From @BotFather on Telegram
DISCORD_BOT_TOKEN=                # From Discord Developer Portal
DISCORD_CLIENT_ID=                # Application ID from Discord Developer Portal
DISCORD_GUILD_ID=                 # Your demo Discord server ID — for instant slash command registration
