# Gemini API
GEMINI_API_KEY=

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Solana (Devnet only)
SOLANA_PUBLIC_KEY=
SOLANA_PRIVATE_KEY=       # Base58 encoded keypair for devnet
