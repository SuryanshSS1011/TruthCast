# Sentry Error Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Database
SQLITE_PATH=./packages/pipeline/db/truthcast.db

# OpenClaw (optional - fallback to Node.js scripts if not set)
USE_OPENCLAW=false
